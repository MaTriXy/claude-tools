{
    "name": "claude-tools",
    "version": "0.1.0",
    "description": "TypeScript library for managing Claude Code session history, secrets, API keys, and more",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "prepare": "tsc",
        "build": "tsc",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "tsc --noEmit"
    },
    "keywords": [
        "claude",
        "claude-code",
        "session-history",
        "mcp"
    ],
    "license": "MIT",
    "dependencies": {},
    "devDependencies": {
        "@types/node": "^22.15.3",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3",
        "vitest": "^3.1.2"
    },
    "engines": {
        "node": ">=20"
    }
}
